# ============================================================================
# OES — Online Enumeration System : Environment variables
# Copy to .env.local and fill in values from your Supabase project settings.
# ============================================================================

# Supabase project API URL (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase anon / publishable key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Supabase service role key (SERVER ONLY — never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public base URL of the deployed app (used for links / metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
